# 統一 SSH 配置（由 dotfiles 管理）
# 機器特定設定請編輯 ~/.ssh/config.local

Include ~/.ssh/config.local

# 私人帳號
Host github.com
    HostName github.com
    User git
    IdentityFile ~/.ssh/id_github
    AddKeysToAgent yes
    IdentitiesOnly yes

# 工作帳號 (jjshen-eland)
Host github-work
    HostName github.com
    User git
    IdentityFile ~/.ssh/id_github_work
    AddKeysToAgent yes
    IdentitiesOnly yes

